# =============================================================================
# Shamba Traceability — example environment file
# Copy to `.env.local` (gitignored) and fill in real values for local dev.
# Never commit real secrets. See docs/development/setup.md for guidance.
# =============================================================================

# ---- General -----------------------------------------------------------------
NODE_ENV=development

# ---- Web app (apps/web) ------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_HASHSCAN_BASE=https://hashscan.io/testnet

# ---- Database (Postgres + PostGIS) ------------------------------------------
DATABASE_URL=postgres://shamba:shamba@localhost:5432/shamba?sslmode=disable

# ---- Redis (queue, rate limits) ---------------------------------------------
REDIS_URL=redis://localhost:6379

# ---- Hedera ------------------------------------------------------------------
# One of: testnet | previewnet | mainnet
HEDERA_NETWORK=testnet
# Operator account that pays for HCS / HTS / contract transactions
HEDERA_OPERATOR_ID=0.0.000000
HEDERA_OPERATOR_PRIVATE_KEY=
# Treasury / relayer account that holds tokens on behalf of users
HEDERA_TREASURY_ID=0.0.000000
HEDERA_TREASURY_PRIVATE_KEY=

# ---- IPFS / storage ----------------------------------------------------------
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080

# ---- Deforestation provider --------------------------------------------------
# One of: gfw | jrc | sentinel-hub | planet
DEFORESTATION_PROVIDER=gfw
GFW_API_KEY=

# ---- DDS / TRACES NT (optional, exporter-side) ------------------------------
TRACES_NT_BASE_URL=
TRACES_NT_CLIENT_ID=
TRACES_NT_CLIENT_SECRET=

# ---- Observability -----------------------------------------------------------
# Optional. Leave blank to disable.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=shamba-traceability
