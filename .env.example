# =============================================================================
# Shamba Traceability — example environment file
# Copy to `.env.local` (gitignored) and fill in real values for local dev.
# Never commit real secrets. See docs/development/setup.md for guidance.
# =============================================================================

# ---- General -----------------------------------------------------------------
NODE_ENV=development

# ---- Web app (apps/web) ------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_HASHSCAN_BASE=https://hashscan.io/testnet

# ---- Auth.js (apps/web) ------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=please-generate-a-real-secret-with-openssl-rand-base64-32
# Public URL the magic-link callback should redirect to. Defaults to NEXT_PUBLIC_APP_URL.
AUTH_URL=http://localhost:3000
# SMTP transport for magic-link delivery. The defaults below match the
# Mailpit container in infra/docker/docker-compose.yml — captured mail is
# visible at http://localhost:8025. Replace with a real SMTP/Resend/Postmark
# config in non-local environments.
EMAIL_SERVER_HOST=localhost
EMAIL_SERVER_PORT=1025
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=no-reply@shamba.local

# ---- Database (Postgres + PostGIS) ------------------------------------------
DATABASE_URL=postgres://shamba:shamba@localhost:5432/shamba?sslmode=disable

# ---- Redis (queue, rate limits) ---------------------------------------------
REDIS_URL=redis://localhost:6379

# ---- Hedera ------------------------------------------------------------------
# One of: testnet | previewnet | mainnet
HEDERA_NETWORK=testnet
# Operator account that pays for HCS / HTS / contract transactions
HEDERA_OPERATOR_ID=0.0.000000
HEDERA_OPERATOR_PRIVATE_KEY=
# Treasury / relayer account that holds tokens on behalf of users
HEDERA_TREASURY_ID=0.0.000000
HEDERA_TREASURY_PRIVATE_KEY=

# ---- Hedera publisher (services/hedera-publisher) ---------------------------
# Base URL of the publisher HTTP service. apps/web calls this after every
# write that needs to commit an event to HCS. Failures are non-fatal: the DB
# row persists with on_chain_* columns null and the UI shows "Pending HCS
# commit". An automatic reconciler is future work — until it ships, pending
# rows stay pending until a manual replay or the reconciler PR lands.
HEDERA_PUBLISHER_URL=http://localhost:8080
# Per-request timeout in milliseconds. Default 10000.
HEDERA_PUBLISHER_TIMEOUT_MS=10000

# ---- Hedera DID issuer (services/did-issuer) --------------------------------
# Base URL of the did-issuer HTTP service. apps/web calls this after creating
# a new actor row to mint a real did:hedera:<network>:<topicId> and rotate
# the placeholder DID. Failures are non-fatal: the actor row persists with
# its did:placeholder:<uuid> stub and the dashboard surfaces the placeholder
# notice. The same reconciler caveat applies — automatic retry is future work.
HEDERA_DID_ISSUER_URL=http://localhost:8081
# Per-request timeout in milliseconds. Default 30000 (issuer mints a topic
# AND submits the document, so it can take longer than a single event publish).
HEDERA_DID_ISSUER_TIMEOUT_MS=30000

# ---- IPFS / storage ----------------------------------------------------------
IPFS_API_URL=http://localhost:5001
IPFS_GATEWAY_URL=http://localhost:8080

# ---- Deforestation provider --------------------------------------------------
# One of: gfw | jrc | sentinel-hub | planet
DEFORESTATION_PROVIDER=gfw
GFW_API_KEY=

# ---- DDS / TRACES NT (optional, exporter-side) ------------------------------
TRACES_NT_BASE_URL=
TRACES_NT_CLIENT_ID=
TRACES_NT_CLIENT_SECRET=

# ---- Observability -----------------------------------------------------------
# Optional. Leave blank to disable.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=shamba-traceability
