# =============================================================================
# DEPLOY-TIME SECRETS TEMPLATE — do NOT commit a filled-in version.
# =============================================================================
# Copy this file to `.env.deploy.local` (which is gitignored by `.env.*.local`)
# and fill in the values from your provider dashboards. The deploy scripts read
# from `.env.deploy.local`; nothing else looks at this file.
#
# Verify it's ignored:
#   git check-ignore .env.deploy.local
# Should print the filename. If it doesn't, STOP and add `.env.deploy.local`
# to .gitignore before filling in values.
# =============================================================================

# ---- Hedera testnet (portal.hedera.com) -------------------------------------
# Operator account pays HBAR for HCS messages, NFT mints, and contract calls.
HEDERA_OPERATOR_ID=0.0.8994985
HEDERA_OPERATOR_PRIVATE_KEY_DER=302...   # the DER-encoded key (publisher needs this form)
HEDERA_OPERATOR_PRIVATE_KEY_HEX=0x747...  # the 0x-prefixed 32-byte hex (forge needs this form)

# Treasury account holds HTS NFT collections (must be DIFFERENT from operator).
HEDERA_TREASURY_ID=0.0.XXXXXXX
HEDERA_TREASURY_PRIVATE_KEY_DER=302...

# ---- Neon Postgres (neon.tech) ----------------------------------------------
# Pooled connection string. Looks like:
#   postgres://USER:PASS@HOST.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgres://...

# ---- Resend (resend.com) ----------------------------------------------------
# API key starting with `re_...`.
RESEND_API_KEY=re_...
# Sender. `onboarding@resend.dev` works without verifying a domain.
EMAIL_FROM=onboarding@resend.dev

# ---- Vercel (vercel.com) ----------------------------------------------------
# These are set once you've linked the project; vercel CLI fills them in.
VERCEL_TEAM_SLUG=
VERCEL_PROJECT_NAME=shamba-traceability

# ---- Fly.io (fly.io) --------------------------------------------------------
# Pick a globally unique app name for the publisher service.
FLY_PUBLISHER_APP=shamba-publisher-yourname

# ---- Hedera EVM smart contracts (filled in by the deploy script) ----------
# Leave these blank to start; the contract-deploy step prints them.
HEDERA_PLOT_REGISTRY_ID=
HEDERA_BATCH_REGISTRY_ID=

# ---- Optional: Global Forest Watch (data-api.globalforestwatch.org) --------
# If you skip this, DEFORESTATION_PROVIDER stays as `mock` which always
# returns "no deforestation". Fine for a first demo.
GFW_API_KEY=
