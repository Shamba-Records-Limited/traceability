# =============================================================================
# Self-host environment template.
#
#   cp infra/self-host/.env.example infra/self-host/.env
#   edit infra/self-host/.env
#   docker compose -f infra/self-host/docker-compose.yml up -d
#
# `.env` is gitignored. Never commit the filled-in version.
# =============================================================================

# ---- Networking + TLS -------------------------------------------------------
# Public hostname pointed at this host (DNS A/AAAA record). Caddy
# auto-provisions Let's Encrypt certs for this. For LAN-only setups,
# put any FQDN here (e.g. shamba.lan) and skip the ACME bits.
SHAMBA_DOMAIN=demo.example.com
# Email for Let's Encrypt registration. Used for cert expiry warnings.
ACME_EMAIL=ops@example.com
# Optional: expose Mailpit's web UI at a separate hostname. Leave blank
# to keep the UI internal (operators tunnel via SSH).
SHAMBA_MAILPIT_DOMAIN=

# ---- App ---------------------------------------------------------------------
# Public URL the magic-link callback redirects to. MUST match the
# SHAMBA_DOMAIN with https://.
NEXT_PUBLIC_APP_URL=https://demo.example.com
NEXT_PUBLIC_HASHSCAN_BASE=https://hashscan.io/testnet
# Generate: openssl rand -base64 32
AUTH_SECRET=please-generate-with-openssl-rand-base64-32

# ---- Database (Postgres + PostGIS in-stack) --------------------------------
POSTGRES_DB=shamba
POSTGRES_USER=shamba
# Generate: openssl rand -base64 24
POSTGRES_PASSWORD=please-generate

# ---- Magic-link email -------------------------------------------------------
# Defaults below talk to the in-stack Mailpit. For real outbound mail
# (Resend / Mailgun / SES / SMTP), override these.
EMAIL_SERVER_HOST=mailpit
EMAIL_SERVER_PORT=1025
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=no-reply@shamba.local

# ---- Hedera ------------------------------------------------------------------
HEDERA_NETWORK=testnet
# Operator + treasury accounts from portal.hedera.com. The operator
# pays for HCS messages / NFT mints / contract calls; the treasury
# holds NFT collections.
HEDERA_OPERATOR_ID=0.0.XXXXXXX
HEDERA_OPERATOR_PRIVATE_KEY=302...
HEDERA_TREASURY_ID=0.0.XXXXXXX
HEDERA_TREASURY_PRIVATE_KEY=302...
HEDERA_PUBLISHER_TIMEOUT_MS=15000
# DID issuer (the separate `services/did-issuer` Go service) is
# optional. Leave blank and actors get a placeholder DID until the
# reconciler retries.
HEDERA_DID_ISSUER_URL=

# ---- Reconciler --------------------------------------------------------------
# Bearer token guarding /api/cron/reconcile. Generate with:
# openssl rand -base64 32
CRON_SECRET=please-generate

# ---- Deforestation provider -------------------------------------------------
# `mock` always returns "no deforestation" — fine for demos.
# `gfw` calls the real GFW Data API; requires GFW_API_KEY.
DEFORESTATION_PROVIDER=mock
GFW_API_KEY=
GFW_DATASET_VERSION=latest

# ---- EVM smart-contract registry --------------------------------------------
# Opt-in. Set to `true` only AFTER you've deployed the registry
# contracts via `contracts/script/Deploy.s.sol` and have the Hedera
# 0.0.<num> ids below.
REGISTRY_CONTRACTS_ENABLED=false
HEDERA_PLOT_REGISTRY_ID=
HEDERA_BATCH_REGISTRY_ID=
HEDERA_REGISTRY_GAS_LIMIT=500000
