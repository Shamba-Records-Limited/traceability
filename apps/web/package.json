{
  "name": "@shamba/web",
  "version": "0.0.0",
  "private": true,
  "description": "Shamba Traceability web application (cooperative, processor, exporter, auditor, consumer)",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest run --passWithNoTests",
    "clean": "rimraf .next .turbo coverage"
  },
  "dependencies": {
    "@shamba/shared-types": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "next": "^15.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.4",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.4",
    "postcss": "^8.5.1",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
