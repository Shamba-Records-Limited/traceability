# Default to LF line endings everywhere; Git normalizes on commit.
* text=auto eol=lf

# Source code
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.go        text eol=lf
*.sol       text eol=lf
*.py        text eol=lf
*.sh        text eol=lf
*.bash      text eol=lf

# Configuration / docs
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.env.example text eol=lf
Dockerfile  text eol=lf
*.dockerfile text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf

# Windows-only scripts
*.cmd       text eol=crlf
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Binaries — never normalize
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.pdf       binary
*.zip       binary
*.tar       binary
*.tar.gz    binary
*.tgz       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.mp4       binary

# GitHub linguist hints
*.sol       linguist-language=Solidity
docs/**     linguist-documentation=true
**/generated/** linguist-generated=true
*.generated.ts  linguist-generated=true
*.generated.go  linguist-generated=true
