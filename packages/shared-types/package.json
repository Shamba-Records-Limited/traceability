{
  "name": "@shamba/shared-types",
  "version": "0.0.0",
  "private": true,
  "description": "Shared domain types and Zod schemas for Shamba Traceability",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./actor": "./src/actor.ts",
    "./batch": "./src/batch.ts",
    "./commodity": "./src/commodity.ts",
    "./common": "./src/common.ts",
    "./dds": "./src/dds.ts",
    "./event": "./src/event.ts",
    "./geometry": "./src/geometry.ts",
    "./handoff": "./src/handoff.ts",
    "./identity": "./src/identity.ts",
    "./plot": "./src/plot.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run",
    "clean": "rimraf .turbo dist coverage"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
